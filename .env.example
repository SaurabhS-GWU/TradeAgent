# Application identity
APP_NAME=TradingAgent

# Environment: development | staging | production
APP_ENV=development

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Market data provider: alpaca
MARKET_DATA_PROVIDER=alpaca

# Alpaca API credentials (https://app.alpaca.markets/)

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here


# Alpaca data feed: IEX (free) or SIP (paid subscription)
ALPACA_DATA_FEED=IEX

# Comma-separated symbols to stream
MARKET_DATA_SYMBOLS=SPY
