# Application identity
APP_NAME=TradingAgent

# Environment: development | staging | production
APP_ENV=development

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Market data provider: alpaca
MARKET_DATA_PROVIDER=alpaca

